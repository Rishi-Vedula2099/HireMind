# ============================================================
# HireMind AI — Environment Variables Template
# Copy this file to backend/.env and frontend/.env.local
# Fill in real values. NEVER commit the filled .env files.
# ============================================================

# ── App ──────────────────────────────────────────────────────
APP_NAME="HireMind AI"
DEBUG=true

# ── Database (PostgreSQL) ─────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/hiremind

# ── Redis ─────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/1

# ── Auth — Clerk (https://clerk.com) ─────────────────────────
# Get keys from: Clerk Dashboard → API Keys
CLERK_SECRET_KEY=sk_test_...
CLERK_PUBLISHABLE_KEY=pk_test_...
CLERK_JWT_ISSUER=https://your-clerk-instance.clerk.accounts.dev

# ── AI — OpenAI (https://platform.openai.com) ────────────────
OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-4o
OPENAI_EMBEDDING_MODEL=text-embedding-3-small

# ── Payments — Stripe (https://dashboard.stripe.com) ─────────
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_PRO_PRICE_ID=price_...

# ── CORS ─────────────────────────────────────────────────────
ALLOWED_ORIGINS=["http://localhost:3000"]

# ── Paths ─────────────────────────────────────────────────────
AI_ENGINE_PATH=../ai-engine
FAISS_INDEX_PATH=../ai-engine/embeddings/index

# ── Frontend (Next.js) ────────────────────────────────────────
# Add to frontend/.env.local:
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_...
NEXT_PUBLIC_API_URL=http://localhost:8000
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...
